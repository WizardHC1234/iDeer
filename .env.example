# Runtime defaults loaded automatically by main.py and scripts/run_daily.sh

# -----------------------------------------------------------------------------
# LLM
# Prefer the standard MODEL_NAME / BASE_URL / API_KEY trio.
# -----------------------------------------------------------------------------
PROVIDER=openai
MODEL_NAME=
BASE_URL=
API_KEY=
TEMPERATURE=0.5

# -----------------------------------------------------------------------------
# Email
# Required if you want the main pipeline to actually send emails.
# -----------------------------------------------------------------------------
SMTP_SERVER=
SMTP_PORT=
SMTP_SENDER=
SMTP_RECEIVER=
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Twitter / X via RapidAPI
# -----------------------------------------------------------------------------
X_RAPIDAPI_KEY=
X_RAPIDAPI_HOST=twitter-api45.p.rapidapi.com
X_ACCOUNTS_FILE=profiles/x_accounts.txt
X_DISCOVER_ACCOUNTS=0
X_MERGE_STATIC_ACCOUNTS=0
X_USE_PERSISTED_ACCOUNTS=0
X_SKIP_DISCOVERY_IF_PERSISTED=1
X_DISCOVERY_PERSIST_FILE=state/x_accounts.discovered.txt
X_PROFILE_FILE=
X_PROFILE_URLS=
X_DISCOVERY_ROUNDS=3
X_DISCOVERY_EXPANSION_ROUNDS=2
X_DISCOVERY_MAX_CANDIDATES=48
X_DISCOVERY_MAX_FINAL_ACCOUNTS=12
X_DISCOVERY_MAX_CORE_ACCOUNTS=12
X_DISCOVERY_MAX_EXTENDED_ACCOUNTS=24
X_DISCOVERY_SEARCH_RESULTS_PER_QUERY=6
X_DISCOVERY_SAMPLE_TWEETS=2
X_DISCOVERY_SEARCH_TIMEOUT=12
X_DISCOVERY_MIN_SCORE=6.0

# -----------------------------------------------------------------------------
# Optional pipeline defaults
# -----------------------------------------------------------------------------
# Paper-first daily reading defaults
DAILY_SOURCES="arxiv semanticscholar huggingface"
NUM_WORKERS=8
DESCRIPTION_FILE=profiles/description.txt

# arXiv
ARXIV_CATEGORIES="cs.AI cs.CL cs.LG"
ARXIV_MAX_ENTRIES=100
ARXIV_MAX_PAPERS=60

# Semantic Scholar
# Use | to separate multiple values, e.g. "multimodal reasoning|agent memory"
SS_QUERIES=
SS_MAX_RESULTS=60
SS_MAX_PAPERS=30
SS_YEAR=
# Use | to separate multiple values, e.g. "Computer Science|Linguistics"
SS_FIELDS_OF_STUDY="Computer Science"
SS_API_KEY=

# GitHub
GH_LANGUAGES="all"
GH_SINCE=daily
GH_MAX_REPOS=30

# HuggingFace
HF_CONTENT_TYPES="papers"
HF_MAX_PAPERS=30
HF_MAX_MODELS=15

# Cross-source report
GENERATE_REPORT=1
REPORT_PROFILE_FILE=profiles/researcher_profile.md
REPORT_TITLE=Daily Personal Briefing
REPORT_MIN_SCORE=4.0
REPORT_MAX_ITEMS=18
REPORT_THEME_COUNT=4
REPORT_PREDICTION_COUNT=4
REPORT_IDEA_COUNT=4
SEND_REPORT_EMAIL=1

# Ideas
GENERATE_IDEAS=1
RESEARCHER_PROFILE=profiles/researcher_profile.md
IDEA_MIN_SCORE=7
IDEA_MAX_ITEMS=15
IDEA_COUNT=5
