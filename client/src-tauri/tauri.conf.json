{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iDeer",
  "version": "0.1.0",
  "identifier": "com.ideer.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "iDeer",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
